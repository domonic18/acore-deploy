[worldserver]

########################################
# mod-feishu-chat configuration
########################################
#
#    FeishuChat.Enabled
#        Description: Enable or disable the Feishu chat forwarding module
#        Default:     0 - Disabled
#                     1 - Enabled
#
#    FeishuChat.WebhookUrl
#        Description: Full URL of the Feishu custom bot webhook.
#                     Example: https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#        Default:     ""
#
#    FeishuChat.Secret
#        Description: Signature verification secret of the Feishu custom bot.
#                     Leave empty if signature verification is disabled.
#        Default:     ""
#
#    FeishuChat.ForwardSay
#        Description: Forward SAY chat messages
#        Default:     1
#
#    FeishuChat.ForwardYell
#        Description: Forward YELL chat messages
#        Default:     1
#
#    FeishuChat.ForwardEmote
#        Description: Forward EMOTE chat messages
#        Default:     1
#
#    FeishuChat.ForwardGuild
#        Description: Forward GUILD chat messages
#        Default:     1
#
#    FeishuChat.ForwardChannel
#        Description: Forward channel chat messages
#        Default:     1
#
#    FeishuChat.FilteredChannels
#        Description: Comma-separated list of channel name substrings to ignore.
#        Default:     "Crb,LFGForwarder,TCForwarder,LFGShout,xtensionxtooltip2,QuickHealMod"
#
#    FeishuChat.MessageFormat
#        Description: Template for text messages. Placeholders:
#                     {player}  - Player name
#                     {level}   - Player level
#                     {class}   - Player class name
#                     {race}    - Player race name
#                     {zone}    - Zone name
#                     {type}    - Chat type (SAY/YELL/EMOTE/GUILD/CHANNEL)
#                     {channel} - Channel name (if applicable)
#                     {message} - Chat message text
#        Default:     "[{type}] {player} (Lv{level} {class}): {message}"
#
#    FeishuChat.HttpTimeoutSeconds
#        Description: HTTP client timeout in seconds
#        Default:     5
#
#    FeishuChat.MaxQueueSize
#        Description: Maximum number of messages queued for forwarding.
#                     Oldest messages are dropped when the limit is exceeded.
#        Default:     1000
#

FeishuChat.Enabled = 0
FeishuChat.WebhookUrl = ""
FeishuChat.Secret = ""

FeishuChat.ForwardSay = 1
FeishuChat.ForwardYell = 1
FeishuChat.ForwardEmote = 1
FeishuChat.ForwardGuild = 1
FeishuChat.ForwardChannel = 1

FeishuChat.FilteredChannels = "Crb,LFGForwarder,TCForwarder,LFGShout,xtensionxtooltip2,QuickHealMod"

FeishuChat.MessageFormat = "[{type}] {player} (Lv{level} {class}): {message}"

FeishuChat.HttpTimeoutSeconds = 5
FeishuChat.MaxQueueSize = 1000
