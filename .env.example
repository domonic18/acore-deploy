# 腾讯云容器镜像服务配置
REGISTRY=ccr.ccs.tencentyun.com
NAMESPACE=your-namespace

# 镜像标签：由 CI 自动生成，格式为 <分支名>-<commit short sha>
#   develop 分支示例：develop-4eb3baf
#   master 分支示例：master-4eb3baf
TAG=develop-4eb3baf

# 数据库连接配置（直接填写完整连接字符串，格式: host;port;user;password;database）
# 这些环境变量会被 AzerothCore ConfigMgr 直接读取，覆盖 .conf 文件中的配置，
# 密码不会写入任何文件。
AC_LOGIN_DATABASE_INFO=your-mysql-host;3306;acore;your-password;acore_auth
AC_WORLD_DATABASE_INFO=your-mysql-host;3306;acore;your-password;acore_world
AC_CHARACTER_DATABASE_INFO=your-mysql-host;3306;acore;your-password;acore_characters

# RealmID 配置（覆盖 worldserver.conf 中的 RealmID）
# 测试环境通常用 3，生产环境可设置为 2 或其他值
AC_REALMID=3

# AzerothCore 源码目录（用于本地构建 db-import 镜像）
# 请填写你本地 AzerothCore 源码的绝对路径
ACORE_DIR=/path/to/azerothcore-wotlk

# mod-feishu-chat 敏感配置（通过环境变量注入，避免写入 .conf）
AC_FEISHU_CHAT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id
AC_FEISHU_CHAT_SECRET=your-feishu-bot-secret
